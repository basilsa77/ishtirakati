rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function hasValidBackupPayload() {
      return request.resource.data.backup is string
          && request.resource.data.backup.size() > 0
          && request.resource.data.backup.size() <= 850000
          && request.resource.data.updatedAt == request.time;
    }

    function hasValidEncryptedBackup() {
      return request.resource.data.keys()
          .hasOnly([
            'backup',
            'updatedAt',
            'schemaVersion',
            'revision',
            'encryption'
          ])
          && hasValidBackupPayload()
          && request.resource.data.schemaVersion == 2
          && request.resource.data.encryption == 'AES-256-GCM'
          && request.resource.data.revision is int
          && request.resource.data.revision > 0;
    }

    function storedRevision() {
      return resource.data.keys().hasAny(['revision'])
          && resource.data.revision is int
          ? resource.data.revision
          : 0;
    }

    match /users/{uid} {
      allow read, delete: if isOwner(uid);
      allow create: if isOwner(uid)
                    && hasValidEncryptedBackup()
                    && request.resource.data.revision == 1;
      allow update: if isOwner(uid)
                    && hasValidEncryptedBackup()
                    && request.resource.data.revision == storedRevision() + 1;
    }
  }
}
