rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function hasValidBackupPayload() {
      return request.resource.data.backup is string
          && request.resource.data.backup.size() > 0
          && request.resource.data.backup.size() <= 850000
          && request.resource.data.schemaVersion == 1
          && request.resource.data.updatedAt == request.time;
    }

    function hasValidLegacyBackup() {
      return request.resource.data.keys()
          .hasOnly(['backup', 'updatedAt', 'schemaVersion'])
          && hasValidBackupPayload();
    }

    function hasValidVersionedBackup() {
      return request.resource.data.keys()
          .hasOnly(['backup', 'updatedAt', 'schemaVersion', 'revision'])
          && hasValidBackupPayload()
          && request.resource.data.revision is int
          && request.resource.data.revision > 0;
    }

    match /users/{uid} {
      allow read, delete: if isOwner(uid);
      allow create: if isOwner(uid)
                    && (
                      hasValidLegacyBackup()
                      || (hasValidVersionedBackup()
                        && request.resource.data.revision == 1)
                    );
      allow update: if isOwner(uid)
                    && (
                      (
                        !resource.data.keys().hasAny(['revision'])
                        && hasValidLegacyBackup()
                      )
                      || (
                        hasValidVersionedBackup()
                        && (
                          (!resource.data.keys().hasAny(['revision'])
                            && request.resource.data.revision == 1)
                          || request.resource.data.revision
                            == resource.data.revision + 1
                        )
                      )
                    );
    }
  }
}
